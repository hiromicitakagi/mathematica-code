Cell[TextData[{
 "To study the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["dp", "1"], TraditionalForm]],ExpressionUUID->
  "c6f2518a-d65f-6d4c-ade9-ba04773ce286"],
 "-fibration, we use the s123 - or s135-chart . Here we use the s123-chart. \
We consider the system consisting of the equations defining the s123 -chart \
and Hypst == 0, together with the sections cutting out \|01d44b from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["\[CapitalPi]",
     FontWeight->"Bold"], 
    RowBox[{"\[DoubleStruckCapitalP]", "."}]], TraditionalForm]],
  ExpressionUUID->"a6da699c-9909-6948-985e-9ec56f887dde"],
 " (The flow of the following argument  is similar to the one for the \
s124-chart as above)."
}], "Text",
 CellChangeTimes->{{3.983662143606367*^9, 3.983662285366396*^9}, {
  3.983662755263317*^9, 3.983662776845667*^9}, {3.983678113279297*^9, 
