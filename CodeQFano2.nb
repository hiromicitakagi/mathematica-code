Cell[TextData[{
 "To study the flipping and flipped loci, we only consider the s124 - chart . \
We consider the system consisting of the equations defining the s124-chart \
S124Eq and Hypst == 0, together with the sections cutting out\n\|01d44b from ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    StyleBox["\[CapitalPi]",
     FontWeight->"Bold"], 
    RowBox[{"\[DoubleStruckCapitalP]", "."}]], TraditionalForm]],
  ExpressionUUID->"bffb9a49-6954-b042-abc5-586267501cfb"],
 "\n",
 StyleBox["  The cutting sections ",
  FontWeight->"Bold"],
 ": {t1 -> a1 z^2, t245 -> a245 z^2, t2 -> a2 t126 + b2 z^3, p2 -> c2 t126 z \
+ d2 z^4, t124 -> a124 t126 z + b124 z^4, t136 -> a136 t126 z + b136 z^4, p1 \
-> b1 t126 z^2 + c1 z^5, t125 -> a125 t126 z^2 + b125 z^5, p4 -> a4 u1 + b4 \
t126^2 + c4 t126 z^3 + d4 z^6, t123 -> a123 u1 + b123 t126^2 + c123 t126 z^3 \
+ d123 z^6, t135 -> a135 u1 + b135 t126^2 + c135 t126 z^3 + d135 z^6}\n\:200b"
}], "Text",
 CellChangeTimes->{{3.983605137793892*^9, 3.9836051511020317`*^9}, {
   3.9836053385318546`*^9, 3.9836054233183517`*^9}, {3.9836054699976215`*^9, 
