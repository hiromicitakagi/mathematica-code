Cell[TextData[{
 "This is the quintic homogeneous polynomial with 5 distinct root for general \
parameters. Thus",
 StyleBox[" the flipping locus consists of 5 distinct rulings ",
  FontWeight->"Bold"],
 "of  \[DoubleStruckCapitalP](s126,z,p3)==\[DoubleStruckCapitalP](1,1,7). The \
vertex of  \[DoubleStruckCapitalP](1,1,7) is a singularity of 3-fold, which \
now we determine."
}], "Text",
 CellChangeTimes->{{3.9836474415380745`*^9, 3.9836475620184746`*^9}, {
  3.9836477399799976`*^9, 3.9836477476042557`*^9}, {3.9836478456671314`*^9, 
