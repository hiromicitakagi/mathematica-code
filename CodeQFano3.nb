   3.9863250570370445`*^9, 3.986325088567173*^9}, {3.9863306733399925`*^9, 
   3.9863306907562523`*^9}},ExpressionUUID->
  "fed89816-8998-f443-871d-c76807e6c0fd"],
 " \[Rule]",
 Cell[BoxData[
  SubscriptBox["P", "1"]], "Text",
  CellChangeTimes->{{3.9863245131174717`*^9, 3.986324625966036*^9}, {
   3.986324662078293*^9, 3.9863247111890736`*^9}, {3.9863247451811123`*^9, 
   3.9863249086678123`*^9}, {3.986325004706398*^9, 3.9863250078178444`*^9}, {
   3.9863250570370445`*^9, 3.986325088567173*^9}, {3.9863306733399925`*^9, 
   3.9863306907562523`*^9}},ExpressionUUID->
  "4344dcd2-9a37-1148-b637-ee7a13897939"],
 "  is graded. For this, it suffices to check that for any i and k, the \
weight of D1_{i,j} D2_{j,k} is independent of  j.  The following code \
verifies this. As a result, the weights of the components of  ",
 Cell[BoxData[
  SubscriptBox["P", "1"]], "Text",
  CellChangeTimes->{{3.9863245131174717`*^9, 3.986324625966036*^9}, {
   3.986324662078293*^9, 3.9863247111890736`*^9}, {3.9863247451811123`*^9, 
   3.9863249086678123`*^9}, {3.986325004706398*^9, 3.9863250078178444`*^9}, {
   3.9863250570370445`*^9, 3.986325088567173*^9}, {3.9863306733399925`*^9, 
   3.9863306907562523`*^9}},ExpressionUUID->
  "2426df44-ecf6-cf4b-9ef2-9bc2cfeb49cb"],
 " (see Proposition 4.9 (1)) are obtained from these common weights."
}], "Text",
 CellChangeTimes->{{3.9863297965044556`*^9, 3.986329803037239*^9}, 
   3.9863306575865784`*^9, {3.986330739474674*^9, 3.9863308949661903`*^9}, {
   3.9863310251643295`*^9, 3.9863310380418816`*^9}, {3.98633115800502*^9, 
   3.9863312488160496`*^9}, {3.986331286347143*^9, 3.9863313766448364`*^9}, {
   3.986331433765562*^9, 3.9863315282057705`*^9}, {3.986331566339857*^9, 
