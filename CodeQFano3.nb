Cell[TextData[{
 "Finally we check that the resulting free resolution is graded with respect\n\
to any choice of nonnegative weights for which all the defining polynomials \
in HEq (see Section 4 above) are homogeneous . By symmetry, we have only to \
check ",
 Cell[BoxData[
  SubscriptBox["P", "2"]], "Text",
  CellChangeTimes->{{3.9863245131174717`*^9, 3.986324625966036*^9}, {
   3.986324662078293*^9, 3.9863247111890736`*^9}, {3.9863247451811123`*^9, 
   3.9863249086678123`*^9}, {3.986325004706398*^9, 3.9863250078178444`*^9}, {
   3.9863250570370445`*^9, 3.986325088567173*^9}, {3.9863306733399925`*^9, 
   3.9863306907562523`*^9}},ExpressionUUID->
  "f017638e-edbc-7b4e-8626-8382efaf1a74"],
 " \[Rule]",
 Cell[BoxData[
  SubscriptBox["P", "1"]], "Text",
  CellChangeTimes->{{3.9863245131174717`*^9, 3.986324625966036*^9}, {
   3.986324662078293*^9, 3.9863247111890736`*^9}, {3.9863247451811123`*^9, 
   3.9863249086678123`*^9}, {3.986325004706398*^9, 3.9863250078178444`*^9}, {
   3.9863250570370445`*^9, 3.986325088567173*^9}, {3.9863306733399925`*^9, 
   3.9863306907562523`*^9}},ExpressionUUID->
  "dccebafc-c91e-c743-874f-db038090f2b4"],
 "  is graded.\n  First, by the following code, we obtain the condition on \
weights of coordinates  such that all the defining polynomials in HEq (see \
Section 4 above) are homogeneous, where varsxp, varsXP are defined in Section \
1."
}], "Text",
 CellChangeTimes->{{3.986328713790077*^9, 3.986328719963545*^9}, {
   3.986328758836214*^9, 3.9863288876974735`*^9}, {3.9863289224732533`*^9, 
   3.986328948934273*^9}, {3.9863334617617664`*^9, 3.9863334705283318`*^9}, 
   3.9863335146545944`*^9},ExpressionUUID->"4ad539ae-7cb2-f54e-af8a-\
9a41579daab2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"weightRules", "=", 
    RowBox[{"Thread", "[", 
     RowBox[{"varsxp", "->", "varsXP"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"monomialWeight", "[", "mon_", "]"}], ":=", 
    RowBox[{"Total", "[", 
     RowBox[{
      RowBox[{"Exponent", "[", 
       RowBox[{"mon", ",", "varsxp"}], "]"}], " ", "varsXP"}], "]"}]}], ";"}],
   "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"conditions", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"mons", ",", "weights"}], "}"}], ",", 
         RowBox[{
          RowBox[{"mons", "=", 
           RowBox[{"MonomialList", "[", 
            RowBox[{
             RowBox[{"HEq", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", "varsxp"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"weights", "=", 
           RowBox[{"monomialWeight", "/@", "mons"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Thread", "[", 
           RowBox[{
            RowBox[{"Rest", "[", "weights", "]"}], "==", 
            RowBox[{"First", "[", "weights", "]"}]}], "]"}]}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", 
         RowBox[{"Length", "[", "HEq", "]"}]}], "}"}]}], "]"}], "]"}]}], 
   ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"wtRelations", "=", 
    RowBox[{"Solve", "[", 
     RowBox[{"conditions", ",", 
      RowBox[{"{", 
       RowBox[{
       "P112", ",", "P121", ",", "P211", ",", "P122", ",", "P212", ",", 
        "P221", ",", "P222", ",", "U1", ",", "U2", ",", "U3"}], "}"}]}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"wtRelations", "//", "First"}]}], "Input",
 CellChangeTimes->{{3.9863290257146587`*^9, 3.986329031276636*^9}},
 CellLabel->
  "In[138]:=",ExpressionUUID->"17d3ac50-4a00-bf42-a1b6-785a67e3cefe"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"P112", "\[Rule]", 
    RowBox[{"P111", "-", "X13", "+", "X23"}]}], ",", 
   RowBox[{"P121", "\[Rule]", 
    RowBox[{"P111", "-", "X12", "+", "X22"}]}], ",", 
   RowBox[{"P211", "\[Rule]", 
    RowBox[{"P111", "-", "X11", "+", "X21"}]}], ",", 
   RowBox[{"P122", "\[Rule]", 
    RowBox[{"P111", "-", "X12", "-", "X13", "+", "X22", "+", "X23"}]}], ",", 
   RowBox[{"P212", "\[Rule]", 
    RowBox[{"P111", "-", "X11", "-", "X13", "+", "X21", "+", "X23"}]}], ",", 
   RowBox[{"P221", "\[Rule]", 
    RowBox[{"P111", "-", "X11", "-", "X12", "+", "X21", "+", "X22"}]}], ",", 
   RowBox[{"P222", "\[Rule]", 
    RowBox[{
    "P111", "-", "X11", "-", "X12", "-", "X13", "+", "X21", "+", "X22", "+", 
     "X23"}]}], ",", 
   RowBox[{"U1", "\[Rule]", 
    RowBox[{"P111", "-", "X11", "+", "X22", "+", "X23"}]}], ",", 
   RowBox[{"U2", "\[Rule]", 
    RowBox[{"P111", "-", "X12", "+", "X21", "+", "X23"}]}], ",", 
   RowBox[{"U3", "\[Rule]", 
    RowBox[{"P111", "-", "X13", "+", "X21", "+", "X22"}]}]}], "}"}]], "Output",
 CellChangeTimes->{3.986328908250826*^9, 3.986329031919565*^9},
 CellLabel->
  "Out[142]=",ExpressionUUID->"d414297e-c21c-5542-a0e7-8efcd396e8d6"]
}, Open  ]],

