Cell["Now we proceed according to the rank of CoMat .", "Text",
 CellChangeTimes->{{3.9859743375184727`*^9, 
  3.9859743987585945`*^9}},ExpressionUUID->"35527ca0-6a8c-a049-90b6-\
a4b9e358f49c"],

Cell[TextData[StyleBox["Case : rank CoMat == 0, i . e .,  x12 == x22 == x13 \
== x23 == 0",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.985937419352068*^9, 3.985937440232994*^9}, {
   3.9859374742536793`*^9, 3.985937515219965*^9}, 
   3.9859377747364273`*^9},ExpressionUUID->"681781a2-59c8-6a48-92fd-\
689ce220cdb9"],

Cell[TextData[{
 "This locus is nothing but ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[DoubleStruckCapitalP]", 
    TemplateBox[<|"boxes" -> FormBox[
        RowBox[{"(", 
          SubscriptBox[
           StyleBox["p", "TI"], 
           RowBox[{
             StyleBox["i", "TI"], 
             StyleBox["j", "TI"], 
             StyleBox["k", "TI"]}]], ")"}], TraditionalForm], "errors" -> {}, 
      "input" -> "$(p_{ijk})$", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], TraditionalForm]],ExpressionUUID->
  "00260e83-31b7-6747-b34a-31d5bdd19cae"],
 ", which is 7-dimensional (",
 StyleBox["codimension 5 in ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        OverscriptBox[
         StyleBox["H", "TI"], "_"], "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\overline{\\mathscr{H}}_2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"2b84c918-7f56-3b40-ac26-a3dadefa9dc7"],
 ").  The condition on  fibers is only FloppedQuad . Thus every fiber over a \
point of this locus is ",
 StyleBox["a quadric surface ",
  FontWeight->"Bold"],
 "."
}], "Text",
 CellChangeTimes->{{3.9859375525902233`*^9, 3.9859375639530067`*^9}, {
  3.985937648297882*^9, 3.9859376636496887`*^9}, {3.9859376980100727`*^9, 
  3.9859377813046265`*^9}, {3.986010553215704*^9, 3.9860105634355316`*^9}, {
  3.9860187567484264`*^9, 3.986018759956167*^9}, {3.9860188467833614`*^9, 
  3.986018881984457*^9}, {3.9860189152704964`*^9, 
  3.9860189446205254`*^9}},ExpressionUUID->"fc66238f-cf83-0948-a1aa-\
d3762947eb91"],

Cell[TextData[StyleBox["Case : rank CoMat == 2",
 FontWeight->"Bold"]], "Text",
 CellChangeTimes->{{3.9859382939922867`*^9, 3.9859383038530617`*^9}, 
   3.9860105821805973`*^9},ExpressionUUID->"e21a1e04-0d4f-7c40-8bbf-\
03477bec1224"],

Cell["\<\
In this case, the fiber is at most 1 - dimesnional . So we omit further \
calculations.\
\>", "Text",
