   3.986333493165924*^9}},ExpressionUUID->"fea3565d-e4f2-3d45-9eb7-\
c4bd38871e04"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"checkByK", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"nonzeroJ", ",", "weights", ",", "distinctWeights"}], "}"}], 
        ",", 
        RowBox[{
         RowBox[{"nonzeroJ", "=", 
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"Range", "[", 
             RowBox[{"Length", "[", 
              RowBox[{"First", "[", "D1", "]"}], "]"}], "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"Expand", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"First", "[", "D1", "]"}], "[", 
                 RowBox[{"[", "#", "]"}], "]"}], " ", 
                RowBox[{"D2", "[", 
                 RowBox[{"[", 
                  RowBox[{"#", ",", "k"}], "]"}], "]"}]}], "]"}], "=!=", 
              "0"}], "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"weights", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"prodWeight", "[", 
             RowBox[{"#", ",", "k"}], "]"}], "&"}], "/@", "nonzeroJ"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"distinctWeights", "=", 
          RowBox[{"DeleteDuplicates", "[", "weights", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<k\>\"", "->", "k"}], ",", 
           RowBox[{"\"\<i+k\>\"", "->", 
            RowBox[{"1", "+", "k"}]}], ",", 
           RowBox[{"\"\<j used\>\"", "->", "nonzeroJ"}], ",", 
           RowBox[{"\"\<distinct weights\>\"", "->", "distinctWeights"}], ",", 
           RowBox[{"\"\<independent of j\>\"", "->", 
            RowBox[{
             RowBox[{"Length", "[", "distinctWeights", "]"}], "==", "1"}]}]}],
           "|>"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"Length", "[", 
         RowBox[{"D2", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"checkByK", "//", "Dataset"}]}], "Input",
 CellLabel->
  "In[165]:=",ExpressionUUID->"229a6406-0138-f24e-ad20-c2046b90a4a3"],

